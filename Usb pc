enum TunnelMode { auto, tcp, udp }

class HomePage extends StatefulWidget {
  const HomePage({super.key});

  @override
  State<HomePage> createState() => _HomePageState();
}

class _HomePageState extends State<HomePage> {
  bool connected = false;
  bool usbDetected = true;
  TunnelMode mode = TunnelMode.auto;

  double downloadMbps = 0.00;
  double uploadMbps = 0.00;
  int pingMs = 0;
  int sessionSeconds = 0;

  Timer? timer;
  final random = Random();

  final List<String> logs = [
    'App iniciado com sucesso.',
    'Aguardando conexao USB...',
  ];

  @override
  void dispose() {
    timer?.cancel();
    super.dispose();
  }

  void startConnection() {
    setState(() {
      connected = true;
      sessionSeconds = 0;
      logs.insert(0, '[OK] Conexao iniciada.');
      logs.insert(0, '[INFO] Modo selecionado: ${modeLabel(mode)}');
    });

    timer?.cancel();
    timer = Timer.periodic(const Duration(seconds: 1), (_) {
      setState(() {
        sessionSeconds++;
        downloadMbps = 30 + random.nextDouble() * 120;
        uploadMbps = 8 + random.nextDouble() * 40;
        pingMs = 8 + random.nextInt(35);

        if (sessionSeconds % 5 == 0) {
          logs.insert(
            0,
            '[SYNC] Down ${downloadMbps.toStringAsFixed(1)} Mbps | Up ${uploadMbps.toStringAsFixed(1)} Mbps | Ping ${pingMs} ms',
          );
        }

        if (logs.length > 18) {
          logs.removeLast();
        }
      });
    });
  }

  void stopConnection() {
    timer?.cancel();
    setState(() {
      connected = false;
      downloadMbps = 0;
      uploadMbps = 0;
      pingMs = 0;
      logs.insert(0, '[STOP] Conexao encerrada.');
      if (logs.length > 18) {
        logs.removeLast();
      }
    });
  }

  String modeLabel(TunnelMode value) {
    switch (value) {
      case TunnelMode.auto:
        return 'AUTO';
      case TunnelMode.tcp:
        return 'TCP';
      case TunnelMode.udp:
        return 'UDP';
    }
  }

  String formatDuration(int seconds) {
    final h = seconds ~/ 3600;
    final m = (seconds % 3600) ~/ 60;
    final s = seconds % 60;
    return '${h.toString().padLeft(2, '0')}:'
        '${m.toString().padLeft(2, '0')}:'
        '${s.toString().padLeft(2, '0')}';
  }

  @override
  Widget build(BuildContext context) {
    final width = MediaQuery.of(context).size.width;

    return Scaffold(
      body: Stack(
        children: [
          const _BackgroundGlow(),
          SafeArea(
            child: LayoutBuilder(
              builder: (context, constraints) {
                final desktop = constraints.maxWidth > 900;

                return SingleChildScrollView(
                  padding: const EdgeInsets.all(20),
                  child: Center(
                    child: ConstrainedBox(
                      constraints: const BoxConstraints(maxWidth: 1200),
                      child: Column(
                        crossAxisAlignment: CrossAxisAlignment.start,
                        children: [
                          _TopHeader(
                            connected: connected,
                            usbDetected: usbDetected,
                          ),
                          const SizedBox(height: 20),
                          desktop
                              ? Row(
                                  crossAxisAlignment: CrossAxisAlignment.start,
                                  children: [
                                    Expanded(
                                      flex: 7,
                                      child: Column(
                                        children: [
                                          _HeroPanel(
                                            connected: connected,
                                            mode: modeLabel(mode),
                                            uptime: formatDuration(sessionSeconds),
                                            onConnect: startConnection,
                                            onDisconnect: stopConnection,
                                          ),
                                          const SizedBox(height: 20),
                                          _StatsGrid(
                                            downloadMbps: downloadMbps,
                                            uploadMbps: uploadMbps,
                                            pingMs: pingMs,
                                            connected: connected,
                                          ),
                                          const SizedBox(height: 20),
                                          _ModeSelector(
                                            value: mode,
                                            onChanged: (v) {
                                              if (v == null) return;
                                              setState(() {
                                                mode = v;
                                                logs.insert(
                                                  0,
                                                  '[MODE] Alterado para ${modeLabel(v)}',
                                                );
                                                if (logs.length > 18) {
                                                  logs.removeLast();
                                                }
                                              });
                                            },
                                          ),
                                        ],
                                      ),
                                    ),
                                    const SizedBox(width: 20),
                                    Expanded(
                                      flex: 5,
                                      child: _LogPanel(logs: logs),
                                    ),
                                  ],
                                )
                              : Column(
                                  children: [
                                    _HeroPanel(
                                      connected: connected,
                                      mode: modeLabel(mode),
                                      uptime: formatDuration(sessionSeconds),
                                      onConnect: startConnection,
                                      onDisconnect: stopConnection,
                                    ),
                                    const SizedBox(height: 20),
                                    _StatsGrid(
                                      downloadMbps: downloadMbps,
                                      uploadMbps: uploadMbps,
                                      pingMs: pingMs,
                                      connected: connected,
                                    ),
                                    const SizedBox(height: 20),
                                    _ModeSelector(
                                      value: mode,
                                      onChanged: (v) {
                                        if (v == null) return;
                                        setState(() {
                                          mode = v;
                                          logs.insert(
                                            0,
                                            '[MODE] Alterado para ${modeLabel(v)}',
                                          );
                                          if (logs.length > 18) {
                                            logs.removeLast();
                                          }
                                        });
                                      },
                                    ),
                                    const SizedBox(height: 20),
                                    _LogPanel(logs: logs),
                                  ],
                                ),
                          const SizedBox(height: 20),
                          _FooterHint(width: width),
                        ],
                      ),
                    ),
                  ),
                );
              },
            ),
          ),
        ],
      ),
    );
  }
}

